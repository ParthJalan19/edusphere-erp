# Server configuration
PORT=5000
NODE_ENV=development

# Database configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/edusphere?retryWrites=true&w=majority

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# JWT Configuration
JWT_ACCESS_SECRET=your_jwt_access_secret_change_me_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_me_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cloudinary Credentials (for private, signed uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100
